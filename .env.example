# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Runtime URL (Prisma Client): use Supabase transaction pooler (PgBouncer).
# Include pgbouncer=true and connection_limit=1 to avoid prepared statement conflicts.
# Supabase pooled URL format:
# DATABASE_URL="postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Direct URL (Prisma CLI migrations/introspection): use direct Postgres host on 5432.
# Supabase direct URL format:
# DIRECT_URL="postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/postgres?sslmode=require"

# -----------------------------------------------------------------------------
# Public URL (used for absolute RSVP links in admin "Copy link")
# -----------------------------------------------------------------------------
# Local:
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production (your Vercel domain or custom domain):
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Admin password gate (/admin/* except /admin/login)
# -----------------------------------------------------------------------------
# Set a strong password. Only people who know it can open the admin UI.
ADMIN_PASSWORD="farhan"

# Secret for signing the admin session cookie (JWT). Min 16 characters; use a long random string.
ADMIN_AUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# Supabase Storage for invite image uploads (required for image upload).
# Usually same project URL as your DB project, e.g. https://<project-ref>.supabase.co
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# Service role key is used server-side for storage upload API route.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
# Optional custom bucket name (defaults to "event-invites")
# SUPABASE_STORAGE_BUCKET="event-invites"

# -----------------------------------------------------------------------------
# Optional: Vercel sets this automatically — you do not need to add it manually.
# Used as a fallback for absolute URLs if NEXT_PUBLIC_APP_URL is unset.
# VERCEL_URL="your-app.vercel.app"
