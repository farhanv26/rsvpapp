// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id            String   @id @default(cuid())
  ownerUserId   String?
  owner         User?    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  title         String
  theme         String   @default("modern")
  slug          String
  description   String?
  imagePath     String?
  coupleNames   String?
  eventSubtitle String?
  eventDate     DateTime?
  rsvpDeadline  DateTime?
  eventTime     String?
  venue         String?
  welcomeMessage String?
  itinerary      Json?
  inviteFontStyle String   @default("elegant_serif")
  inviteMessageIntro String?
  inviteMessageLineOverride String?
  genericCardImage String?
  cardImage1       String?
  cardImage2       String?
  cardImage3       String?
  cardImage4       String?
  familyCardImage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  guests        Guest[]
  rsvpActivities RsvpActivity[]
  communicationLogs GuestCommunicationLog[]

  @@index([slug])
  @@index([ownerUserId, createdAt(sort: Desc)])
  @@index([ownerUserId, deletedAt])
}

model User {
  id           String   @id @default(cuid())
  name         String
  passwordHash String
  role         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  events       Event[]
  guestCommunicationLogs GuestCommunicationLog[]

  @@index([name])
  @@index([active, name])
}

model AuditActivity {
  id          String   @id @default(cuid())
  eventId     String?
  userId      String?
  userName    String
  actionType  String
  entityType  String
  entityId    String
  entityName  String?
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([eventId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([actionType, createdAt(sort: Desc)])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  entityType  String
  entityId    String
  eventId     String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
  @@index([eventId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model Guest {
  id             String   @id @default(cuid())
  eventId        String
  guestName      String
  greeting       String   @default("Assalamu Alaikum")
  menCount       Int      @default(0)
  womenCount     Int      @default(0)
  kidsCount      Int      @default(0)
  maxGuests      Int
  token          String
  attending      Boolean?
  attendingCount Int?
  respondedAt    DateTime?
  group          String?
  tableName      String?
  notes          String?
  hostMessage    String?
  isFamilyInvite Boolean  @default(false)
  /** E.g. "+1", "+44". When null, `phone` may be a legacy full/international string. */
  phoneCountryCode String?
  /** National digits (no country code) when `phoneCountryCode` is set; otherwise legacy full phone text. */
  phone          String?
  email          String?
  invitedAt              DateTime?
  inviteChannelLastUsed  String?
  inviteCount            Int      @default(0)
  lastReminderAt         DateTime?
  excludeFromTotals      Boolean  @default(false)
  excludeReason          String?
  excludedGuestCount     Int      @default(0)
  excludedMenCount       Int      @default(0)
  excludedWomenCount     Int      @default(0)
  excludedKidsCount      Int      @default(0)
  sharedGuestKey         String?
  countOwnerEventId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvpActivities RsvpActivity[]
  communicationLogs GuestCommunicationLog[]

  @@index([eventId])
  @@index([eventId, deletedAt])
  @@index([eventId, excludeFromTotals])
  @@index([sharedGuestKey, deletedAt])
  @@index([countOwnerEventId])
  @@index([token])
}

model GuestCommunicationLog {
  id        String   @id @default(cuid())
  eventId   String
  guestId   String
  userId    String?
  actorName String?
  channel   String
  actionKey String
  label     String
  detail    String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([guestId, createdAt(sort: Desc)])
  @@index([eventId, createdAt(sort: Desc)])
}

model RsvpActivity {
  id          String   @id @default(cuid())
  eventId     String
  guestId     String
  type        String
  description String
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt(sort: Desc)])
  @@index([guestId, createdAt(sort: Desc)])
}
