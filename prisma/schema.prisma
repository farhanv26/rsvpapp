// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id            String   @id @default(cuid())
  ownerUserId   String?
  owner         User?    @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  title         String
  theme         String   @default("modern")
  slug          String   @unique
  description   String?
  imagePath     String?
  coupleNames   String?
  eventSubtitle String?
  eventDate     DateTime?
  rsvpDeadline  DateTime?
  eventTime     String?
  venue         String?
  welcomeMessage String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  guests        Guest[]
  rsvpActivities RsvpActivity[]

  @@index([ownerUserId, createdAt(sort: Desc)])
}

model User {
  id           String   @id @default(cuid())
  name         String   @unique
  passwordHash String
  role         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  events       Event[]

  @@index([active, name])
}

model AuditActivity {
  id          String   @id @default(cuid())
  eventId     String?
  userId      String?
  userName    String
  actionType  String
  entityType  String
  entityId    String
  entityName  String?
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([eventId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([actionType, createdAt(sort: Desc)])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  entityType  String
  entityId    String
  eventId     String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
  @@index([eventId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model Guest {
  id             String   @id @default(cuid())
  eventId        String
  guestName      String
  greeting       String   @default("Assalamu Alaikum")
  maxGuests      Int
  token          String   @unique
  attending      Boolean?
  attendingCount Int?
  respondedAt    DateTime?
  group          String?
  notes          String?
  hostMessage    String?
  phone          String?
  email          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvpActivities RsvpActivity[]

  @@index([eventId])
  @@index([token])
}

model RsvpActivity {
  id          String   @id @default(cuid())
  eventId     String
  guestId     String
  type        String
  description String
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt(sort: Desc)])
  @@index([guestId, createdAt(sort: Desc)])
}
